# Copy to .env.local for local dev, and set the same var in your host (Vercel).
#
# Public base URL of your Cloudflare R2 bucket that holds the video files.
# Videos are referenced as /media/<file>.mp4 in code, so upload them into a
# "media/" folder in the bucket and point this at the bucket root.
#   e.g. https://media.devbyfree.com   (custom domain)
#   or   https://pub-xxxxxxxx.r2.dev   (R2 public dev URL)
#
# Leave UNSET locally to serve videos from /public/media on disk.
NEXT_PUBLIC_MEDIA_BASE_URL=
